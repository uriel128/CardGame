<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="12" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.cardgame.Card24Controller" styleClass="root-pane">
    <padding>
        <Insets top="10" right="14" bottom="10" left="14"/>
    </padding>

    <HBox alignment="CENTER" spacing="10">
        <Button text="Find a Solution" onAction="#findSolution" styleClass="action-button"/>
        <TextField fx:id="solutionField" editable="false" promptText="(6 + 6) * 12 / 6" styleClass="top-field"/>
        <Button text="Refresh" onAction="#refreshCards" styleClass="action-button"/>
    </HBox>

    <HBox alignment="CENTER" spacing="10" styleClass="cards-row">
        <ImageView fx:id="cardImage1" fitWidth="188" preserveRatio="true" smooth="true" styleClass="card-image"/>
        <ImageView fx:id="cardImage2" fitWidth="188" preserveRatio="true" smooth="true" styleClass="card-image"/>
        <ImageView fx:id="cardImage3" fitWidth="188" preserveRatio="true" smooth="true" styleClass="card-image"/>
        <ImageView fx:id="cardImage4" fitWidth="188" preserveRatio="true" smooth="true" styleClass="card-image"/>
    </HBox>

    <Label fx:id="cardValuesLabel" styleClass="values-label"/>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Enter an expression:" styleClass="entry-label"/>
        <TextField fx:id="expressionField" promptText="(6 + 6) * 12 / 6" styleClass="expression-field"/>
        <Button text="Verify" onAction="#verifyExpression" styleClass="action-button"/>
    </HBox>
</VBox>
